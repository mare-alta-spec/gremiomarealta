<!DOCTYPE html>
<html lang="pt-BR">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Grêmio Estudantil Maré Alta</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{
background:linear-gradient(to bottom,#eef8ff,#d7ecff);
min-height:100vh;
overflow-x:hidden;
}

/* CABEÇALHO */

header{
background:rgba(255,255,255,.95);
padding:30px;
position:relative;
text-align:center;
border-bottom:5px solid #2c7be5;
overflow:hidden;
}

/* CARPAS DO TOPO */

header::before{
content:"";
position:absolute;
left:30px;
top:10px;
width:230px;
height:230px;
background:url("carpas.png");
background-size:contain;
background-repeat:no-repeat;
opacity:.9;
}

header::after{
content:"";
position:absolute;
right:30px;
top:10px;
width:230px;
height:230px;
background:url("carpas.png");
background-size:contain;
background-repeat:no-repeat;
transform:scaleX(-1);
opacity:.9;
}

.logo{
position:relative;
z-index:5;
}

.logo h1{
font-size:80px;
color:#0b3b91;
font-family:cursive;
}

.logo p{
font-size:28px;
color:#347dff;
margin-top:10px;
}

/* MENU */

nav{
background:#001f5c;
display:flex;
justify-content:center;
flex-wrap:wrap;
}

nav button{
background:none;
border:none;
color:white;
padding:20px 35px;
font-size:20px;
cursor:pointer;
transition:.3s;
}

nav button:hover{
background:#1d4ed8;
}

/* PÁGINAS */

.pagina{
display:none;
padding:25px;
}

.ativa{
display:block;
}

/* PRINCIPAL */

.principal-grid{
display:grid;
grid-template-columns:1fr 2fr 1fr;
gap:20px;
}

/* CARDS */

.card{
background:white;
padding:25px;
border-radius:20px;
border:2px solid #b6dcff;
box-shadow:0 10px 25px rgba(0,0,0,.08);
}

/* TITULOS */

.card h2{
color:#0b3b91;
margin-bottom:15px;
}

/* INTEGRANTES */

.mini-integrantes{
display:flex;
flex-direction:column;
gap:10px;
}

.integrante{
display:flex;
align-items:center;
gap:10px;
padding:10px;
border-radius:12px;
cursor:pointer;
transition:.3s;
background:#f6fbff;
border:1px solid #dbeeff;
}

.integrante:hover{
background:#eaf5ff;
transform:translateY(-3px);
}

.foto{
width:55px;
height:55px;
border-radius:50%;
object-fit:cover;
border:3px solid #5fa8ff;
}

.biografia{
display:none;
margin-top:10px;
padding:10px;
background:#f6fbff;
border-radius:10px;
font-size:14px;
}

/* CONTATO */

textarea{
width:100%;
height:120px;
padding:10px;
border-radius:10px;
border:1px solid #cbd5e1;
resize:none;
}

/* CARPAS DECORATIVAS */

.carpas-fundo-esq{
position:fixed;
left:20px;
bottom:20px;
width:180px;
opacity:.18;
pointer-events:none;
}

.carpas-fundo-dir{
position:fixed;
right:20px;
bottom:20px;
width:180px;
opacity:.18;
transform:rotate(180deg);
pointer-events:none;
}

/* RESPONSIVO */

@media(max-width:1000px){

.principal-grid{
grid-template-columns:1fr;
}

.logo h1{
font-size:50px;
}

header::before,
header::after{
display:none;
}

}

</style>

</head>

