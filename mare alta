<script>

function mostrar(id){

document.querySelectorAll('.pagina')
.forEach(p=>{
p.classList.remove('ativa');
});

document.getElementById(id)
.classList.add('ativa');

}

function bio(id){

let b=document.getElementById(id);

if(b.style.display==="block"){
b.style.display="none";
}else{
b.style.display="block";
}

}

</script>

